{
  "name": "@japanese-tts-analyzer/analyze-backend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "generate-types": "wrangler types",
    "type-check": "pnpm --filter @japanese-tts-analyzer/accent-ir build && pnpm run generate-types && tsc -p tsconfig.worker.json --noEmit && tsc -p tsconfig.node.json --noEmit",
    "build:container": "tsdown",
    "build": "pnpm --filter @japanese-tts-analyzer/accent-ir build && pnpm run type-check && pnpm run build:container",
    "lint": "eslint .",
    "test": "pnpm --filter @japanese-tts-analyzer/accent-ir build && vitest run",
    "preview": "pnpm run build && wrangler dev",
    "deploy": "pnpm run build && wrangler deploy"
  },
  "dependencies": {
    "@cloudflare/containers": "^0.2.2",
    "@japanese-tts-analyzer/accent-ir": "workspace:*",
    "@japanese-tts-analyzer/analyze-contract": "workspace:*"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "tsdown": "^0.21.10",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5",
    "wrangler": "^4.85.0"
  }
}
