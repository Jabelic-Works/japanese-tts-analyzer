{
  "name": "@japanese-tts-analyzer/tts-playground",
  "private": true,
  "version": "0.0.0",
  "files": [
    "dist",
    "worker",
    "wrangler.jsonc"
  ],
  "type": "module",
  "scripts": {
    "dev": "vite",
    "generate-types": "wrangler types",
    "type-check": "pnpm run generate-types && vue-tsc -b",
    "build": "pnpm --filter @japanese-tts-analyzer/accent-ir build && pnpm run type-check && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "preview:worker": "pnpm run build && wrangler dev",
    "deploy": "pnpm run build && wrangler deploy",
    "test": "echo 'No tests specified for tts-playground'"
  },
  "dependencies": {
    "@japanese-tts-analyzer/accent-ir": "workspace:*",
    "@japanese-tts-analyzer/analyze-contract": "workspace:*",
    "naive-ui": "^2.44.1",
    "vue": "^3.5.31"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitejs/plugin-vue": "^6.0.5",
    "eslint": "^10.1.0",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.3",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.6",
    "wrangler": "^4.79.0"
  }
}
